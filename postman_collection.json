{
  "info": {
    "name": "NestJS API",
    "description": "Endpoints del proyecto Nest.js",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "GET - Obtener todos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["users"]
            }
          }
        },
        {
          "name": "GET - Obtener por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/users/{{user_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["users", "{{user_id}}"]
            }
          }
        },
        {
          "name": "POST - Crear usuario",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Juan Perez\",\n    \"email\": \"juan@email.com\",\n    \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["users"]
            }
          }
        },
        {
          "name": "PUT - Reemplazar usuario",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Juan Actualizado\",\n    \"email\": \"juan.nuevo@email.com\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/users/{{user_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["users", "{{user_id}}"]
            }
          }
        },
        {
          "name": "DELETE - Eliminar usuario",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/users/{{user_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["users", "{{user_id}}"]
            }
          }
        }
      ]
    }
  ]
}
